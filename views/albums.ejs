<%- include('header', { page: 'albums' }) %>

<div class="page-header">
  <div>
    <h1>💿 จัดการอัลบั้ม</h1>
  </div>
  <a href="/albums/new" class="btn btn-primary">➕ เพิ่มอัลบั้มใหม่</a>
</div>

<% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error">
    ⚠️ <%= error %>
  </div>
<% } %>

<!-- Filter Section -->
<div class="filter-section">
  <h3>🔍 กรองข้อมูล</h3>
  <form action="/albums" method="GET" class="filter-form">
    <div class="filter-group">
      <label for="artist_id">ศิลปิน:</label>
      <select name="artist_id" id="artist_id">
        <option value="">-- ทั้งหมด --</option>
        <% artists.forEach(artist => { %>
          <option value="<%= artist.artist_id %>" 
                  <%= filters.artist_id == artist.artist_id ? 'selected' : '' %>>
            <%= artist.artist_name %>
          </option>
        <% }); %>
      </select>
    </div>
    
    <div class="filter-group">
      <label for="release_year">ปี:</label>
      <input type="number" name="release_year" id="release_year" 
             value="<%= filters.release_year || '' %>" 
             placeholder="เช่น 1980" min="1900" max="2100">
    </div>
    
    <div class="filter-actions">
      <button type="submit" class="btn btn-primary">กรอง</button>
      <a href="/albums" class="btn btn-secondary">ล้าง</a>
    </div>
  </form>
</div>

<div class="table-container">
  <table class="data-table">
    <thead>
      <tr>
        <th>ID</th>
        <th>ชื่ออัลบั้ม</th>
        <th>ปี</th>
        <th>ศิลปิน</th>
        <th>จำนวนเพลง</th>
        <th>จัดการ</th>
      </tr>
    </thead>
    <tbody>
      <% if (albums.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center">ไม่มีข้อมูลอัลบั้ม</td>
        </tr>
      <% } else { %>
        <% albums.forEach(album => { %>
          <tr>
            <td><%= album.album_id %></td>
            <td><strong><%= album.album_title %></strong></td>
            <td><%= album.release_year %></td>
            <td><%= album.artist ? album.artist.artist_name : '-' %></td>
            <td><%= album.songs ? album.songs.length : 0 %> เพลง</td>
            <td class="actions">
              <a href="/albums/<%= album.album_id %>/edit" class="btn btn-sm btn-edit">✏️ แก้ไข</a>
              <form action="/albums/<%= album.album_id %>/delete" method="POST" style="display: inline;" 
                    onsubmit="return confirm('คุณต้องการลบอัลบั้มนี้หรือไม่?');">
                <button type="submit" class="btn btn-sm btn-delete">🗑️ ลบ</button>
              </form>
            </td>
          </tr>
        <% }); %>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('footer') %>
